
<section id="blog">
    <article id="article" class="roundbox">
      <header>
      {{#with meta}}

        <h1>
          {{title}}
        </h1>
        
        <div class="article-metadata">
          <p  id="article-author" class="byline vcard">
            <address class="author">
              By 
              <a  class="url fn n" rel="author" href="{{ author_profile }}" 
                  target="_blank" rel="noreferrer noopener">
                {{ author }}
              </a>
              </address> 
            on 
            <time title="{{ date_created }}" pubdate datetime="{{ date_created}}" >
              {{ date_created }}
            </time>

          </p>
        </div>

        <div class="article-img-container">
          <img src="{{aritcle_img_url}}" alt="{{aritcle_img_alt}}">
        </div>
      {{/with}}
      </header>
      
        <!--#region Article Content -->
      <section class="article-content">

        {{{content}}}

      </section>
        <!--#endregion -->

      {{!-- <aside> --}}
        {{!-- related articles partial here ex: If is a tutorial that expand over several articles --}}
      {{!-- </aside> --}}
    </article>


{{!-- latest articles partial this is for the latest articles in the blog --}}
  {{> articles }}
</section>